# Core database/auth
DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase URL (either variable name is supported)
NEXT_PUBLIC_SUPABASE_URL=
# Optional alias for compatibility
SUPABASE_URL=

# Supabase public key (any one of these names is supported)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=

# Optional auth aliases also supported by code
AUTH_SECRET=
AUTH_URL=

# OTP email delivery (required for email OTP login)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional dedicated hashing secret for OTP values
# Falls back to NEXTAUTH_SECRET/AUTH_SECRET when empty
OTP_HASH_SECRET=

# Optional Google login provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Existing media variables
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Healthcare AI integration (optional; fallback guidance is used if not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Healthcare public API behavior
# In production, demo fallback is disabled by default to avoid masking live-data issues.
# Set to true only if you explicitly want demo doctors/slots when live reads fail.
HEALTHCARE_ALLOW_DEMO_FALLBACK=

# Healthcare admin/bootstrap controls
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias for compatibility
SUPABASE_SECRET_KEY=
