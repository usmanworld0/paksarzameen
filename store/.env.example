# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# NextAuth — BOTH vars are required in Vercel project settings (Settings → Environment Variables)
# Generate a strong secret with: openssl rand -base64 32
# If your deployment uses Auth.js-style names, set AUTH_SECRET/AUTH_URL to the same values.
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://store.paksarzameenwfo.com"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Admin seed credentials (only used during initial setup)
ADMIN_EMAIL="admin@gmail.com"
ADMIN_PASSWORD="admin123"

# Public
NEXT_PUBLIC_SITE_URL="https://store.paksarzameenwfo.com"
NEXT_PUBLIC_MAIN_SITE_URL="https://paksarzameenwfo.com"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
